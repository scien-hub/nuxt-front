{
    "name": "@scienhub/frontend",
    "private": true,
    "type": "module",
    "version": "0.0.1",
    "description": "Scienhub Frontend",
    "author": "ScienHub",
    "scripts": {
        "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
        "dev": "nuxt dev",
        "format": "prettier . --write && eslint . --fix",
        "generate": "NODE_OPTIONS='--max-old-space-size=4096' nuxt generate",
        "lint": "eslint .",
        "prepare": "husky",
        "prettier": "prettier .",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare && patch-package || true && husky",
        "typecheck": "tsc --noEmit",
        "ncu": "npx npm-check-updates"
    },
    "dependencies": {
        "@codemirror/view": "^6.38.0",
        "@nuxt/content": "^3.6.2",
        "@nuxt/fonts": "^0.11.4",
        "@nuxt/icon": "^1.15.0",
        "@nuxt/image": "^1.10.0",
        "@nuxt/ui-pro": "^3.2.0",
        "@unhead/vue": "^2.0.11",
        "better-sqlite3": "^11.10.0",
        "codemirror": "^6.0.2",
        "date-fns": "^4.1.0",
        "motion-v": "^1.4.0",
        "nuxt": "^3.17.6",
        "nuxt-gtag": "^3.0.3",
        "pdfjs-dist": "^5.3.31",
        "y-codemirror.next": "^0.3.5",
        "y-websocket": "^3.0.0"
    },
    "devDependencies": {
        "@iconify-json/logos": "^1.2.4",
        "@iconify-json/lucide": "^1.2.54",
        "@iconify-json/mdi": "^1.2.3",
        "@iconify-json/simple-icons": "^1.2.41",
        "@iconify-json/vscode-icons": "^1.2.23",
        "@nuxt/eslint": "^1.5.2",
        "@nuxt/scripts": "^0.11.8",
        "@nuxt/test-utils": "^3.19.2",
        "@stylistic/eslint-plugin-js": "^4.4.1",
        "@stylistic/eslint-plugin-ts": "^4.4.1",
        "@tailwindcss/typography": "^0.5.16",
        "eslint": "^9.30.1",
        "eslint-plugin-vue": "^10.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "patch-package": "^8.0.0",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.13",
        "tailwindcss": "^4.1.11",
        "typescript": "^5.8.3"
    },
    "lint-staged": {
        "*.{ts,vue,json}": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}
